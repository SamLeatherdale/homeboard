# Copy this to .env.local and set the values

VITE_HASS_URL=http://localhost:8123
VITE_ENTITY_WEATHER=weather.home
VITE_ENTITY_CLIMATE=climate.room
# Find these by going to https://trainboard.samleatherdale.com/ and searching for a stop
VITE_ORIGIN_STOP_ID=<TFNSW Stop ID>
VITE_DESTINATION_STOP_IDS=<TFNSW Stop ID>[,<TFNSW Stop ID>]...

# Long-lived access token: used by types:gen and optional local HassConnect login bypass
# https://developers.home-assistant.io/docs/auth_api/#long-lived-access-token
VITE_HASS_TOKEN=
